# ==========================================================
# Environment Variables — copy this file to `.env` and fill in
# your real values. Never commit the real `.env` file.
# ==========================================================

# Your OpenAI API key.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY="Openapi_key"

# OpenAI model to use (kept configurable so you can upgrade later)
OPENAI_MODEL=gpt-4o-mini

# Flask environment: development | production
FLASK_ENV=development

# Port the Flask server runs on
PORT=5000

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max resume upload size in megabytes
MAX_UPLOAD_MB=5
